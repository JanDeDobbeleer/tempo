{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["owner"]
    },
    {
      "route": "/*",
      "allowedRoles": ["owner"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    }
  },
  "platform": {
    "apiRuntime": "node:22"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/*.{png,jpg,jpeg,svg,ico,css,js,json}"]
  }
}
